# ============================================================
#  Rankridge — performance (compression + caching)
#  Safe: affects delivery only, never markup or visuals.
# ============================================================

# ---------- GZIP / DEFLATE compression ----------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml
  AddOutputFilterByType DEFLATE text/css
  AddOutputFilterByType DEFLATE application/javascript application/x-javascript text/javascript
  AddOutputFilterByType DEFLATE application/json
  AddOutputFilterByType DEFLATE image/svg+xml
  AddOutputFilterByType DEFLATE application/vnd.ms-fontobject font/ttf font/otf font/woff font/woff2
</IfModule>

# ---------- Brotli (if available — better than gzip) ----------
<IfModule mod_brotli.c>
  AddOutputFilterByType BROTLI_COMPRESS text/html text/plain text/xml text/css
  AddOutputFilterByType BROTLI_COMPRESS application/javascript application/x-javascript text/javascript
  AddOutputFilterByType BROTLI_COMPRESS application/json image/svg+xml
  AddOutputFilterByType BROTLI_COMPRESS application/vnd.ms-fontobject font/ttf font/otf font/woff font/woff2
</IfModule>

# ---------- Browser caching ----------
<IfModule mod_expires.c>
  ExpiresActive On

  # Images — cache long; filenames/versioning bust the cache
  ExpiresByType image/jpeg                "access plus 1 year"
  ExpiresByType image/png                 "access plus 1 year"
  ExpiresByType image/webp                "access plus 1 year"
  ExpiresByType image/svg+xml             "access plus 1 year"
  ExpiresByType image/x-icon              "access plus 1 year"

  # Fonts
  ExpiresByType font/woff2                "access plus 1 year"
  ExpiresByType font/woff                 "access plus 1 year"
  ExpiresByType application/vnd.ms-fontobject "access plus 1 year"

  # CSS & JS — cached, but ?v= query string forces refresh on change
  ExpiresByType text/css                  "access plus 1 month"
  ExpiresByType application/javascript    "access plus 1 month"
  ExpiresByType text/javascript           "access plus 1 month"

  # HTML — short, so content updates show quickly
  ExpiresByType text/html                 "access plus 0 seconds"
</IfModule>

# ---------- Cache-Control headers ----------
<IfModule mod_headers.c>
  <FilesMatch "\.(jpg|jpeg|png|webp|svg|ico|woff2?|eot|ttf|otf)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>
  <FilesMatch "\.(html)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>
